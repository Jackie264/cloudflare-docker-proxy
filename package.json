{
  "name": "cloudflare-docker-proxy",
  "private": true,
  "description": "Cloudflare Worker proxy for Docker registries",
  "version": "1.0.0",
  "author": "ciiiii <allen.cccccnm@gmail.com>",
  "dependencies": {},
  "devDependencies": {
    "prettier": "^3.6.2",
    "webpack": "^5.101.3",
    "webpack-cli": "^6.0.1",
    "wrangler": "^4.37.0"
  },
  "scripts": {
    "format": "prettier --write '**/*.{js,css,json,md}'",
    "check-format": "prettier --check '**/*.{js,css,json,md}'",
    "clean": "rm -rf dist",
    "build": "webpack",
    "start": "npm run dev",
    "dev": "wrangler dev src/index.js --env dev",
    "deploy:dev": "wrangler deploy --env dev",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:prod": "wrangler deploy --env production"
  },
  "license": "MIT",
  "main": "src/index.js"
}
